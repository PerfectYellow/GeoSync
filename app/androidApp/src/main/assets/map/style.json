{
  "version": 8,
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "tehran": {
      "type": "vector",
      "url": "pmtiles://file://{PMTILES_PATH}",
      "minzoom": 0,
      "maxzoom": 14
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f8f4f0"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "tehran",
      "source-layer": "water",
      "paint": {
        "fill-color": "#a0c8f0"
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "tehran",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#e0dfdf"
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "tehran",
      "source-layer": "building",
      "paint": {
        "fill-color": "#d6d1cb",
        "fill-outline-color": "#c0bab1"
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "tehran",
      "source-layer": "transportation",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate", ["exponential", 1.5], ["zoom"],
          10, 0.5,
          15, 4,
          18, 12
        ]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "tehran",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk", "primary"],
      "paint": {
        "line-color": "#f9d0d0",
        "line-width": [
          "interpolate", ["exponential", 1.5], ["zoom"],
          10, 1,
          15, 6,
          18, 15
        ]
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "tehran",
      "source-layer": "place",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          10, 10,
          15, 16
        ]
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "poi-labels",
      "type": "symbol",
      "source": "tehran",
      "source-layer": "poi",
      "minzoom": 14,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    }
  ]
}
